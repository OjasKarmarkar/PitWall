# PitWall — environment variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# Shared secret set in App Store Connect → Users and Access → Webhooks
APPLE_WEBHOOK_SECRET=your-secret-here

# Slack incoming webhook URL
# Create one at: your-workspace.slack.com/apps/manage/custom-integrations
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Google Play Console poller
# Path to a service-account JSON key with androidpublisher scope
GOOGLE_CREDENTIALS_FILE=./creds.json

# How often to poll the Play API, in seconds (default: 3600)
POLL_INTERVAL_SECONDS=3600

# --- Multi-app mode (preferred) ---
# Semicolon-separated list of "packageName:track1,track2" entries.
# Example: one app on two tracks, plus a second app on production only.
PLAY_APPS=com.example.app:production,beta;com.example.other:production

# --- Single-app fallback (mutually exclusive with PLAY_APPS) ---
# PLAY_PACKAGE_NAME=com.pit.wall
# PLAY_TRACK=production

# App Store Connect API credentials (for enriching Apple webhook notifications)
# Key ID and Issuer ID from App Store Connect → Users and Access → Integrations → Keys
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Private key from the downloaded .p8 file — can be provided as:
#   (a) raw base64 body only (no headers), or
#   (b) single-line: -----BEGIN PRIVATE KEY-----<base64>-----END PRIVATE KEY-----
ASC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----MIGHAgEA...-----END PRIVATE KEY-----
